# Copy this file to .env — NEVER commit your real .env to git.
#   cp .env.example .env
#
# DataBuddy uses Ollama locally — no API key required by default.
# Override these if you change the model or endpoint.

# Ollama OpenAI-compatible endpoint (default: http://localhost:11434/v1)
OLLAMA_BASE_URL=http://localhost:11434/v1

# Model to use (must be pulled with: ollama pull <model>)
MODEL=minimax-m3:cloud
